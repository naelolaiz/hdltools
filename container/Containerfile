# syntax=docker/dockerfile:1

# ---- Build Yosys + ghdl-yosys-plugin from source in a throwaway stage ----
FROM docker.io/ghdl/ghdl:6.0.0-llvm-ubuntu-22.04 AS yosys-builder
ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update \
 && apt-get install -y --no-install-recommends \
      ca-certificates git make g++ python3 \
      bison flex gawk clang libffi-dev libfl-dev libreadline-dev \
      pkg-config tcl-dev zlib1g-dev \
 && rm -rf /var/lib/apt/lists/*

WORKDIR /src
RUN git clone --depth 1 --recurse-submodules --shallow-submodules \
      https://github.com/YosysHQ/yosys.git \
 && make -C yosys -j"$(nproc)" \
 && make -C yosys install

# Pinned: commit just before the plugin started calling Sname_Index / get_sname_index,
# which aren't in the ghdl 6.0.0 base image. Bump when the base ghdl version is bumped.
ARG GHDL_YOSYS_PLUGIN_REF=07a30ed39fb6a078f1bf7e9e88ce9ed712380ec2
RUN git clone https://github.com/ghdl/ghdl-yosys-plugin.git \
 && git -C ghdl-yosys-plugin checkout "$GHDL_YOSYS_PLUGIN_REF" \
 && make -C ghdl-yosys-plugin -j"$(nproc)" \
 && make -C ghdl-yosys-plugin install


# ---- Runtime image ----
FROM docker.io/ghdl/ghdl:6.0.0-llvm-ubuntu-22.04
ENV DEBIAN_FRONTEND=noninteractive

# libghdl has its std/ieee path baked in from GHDL's own CI build
# (/home/runner/work/ghdl/ghdl/...) so the yosys -m ghdl pipeline can't
# find the VHDL standard libraries unless we set GHDL_PREFIX to the real
# location inside the pinned base image. If the base image layout ever
# changes, the CI smoke test in docker-image.yml fails loudly before the
# image is published.
ENV GHDL_PREFIX=/opt/ghdl/lib/ghdl

RUN apt-get update \
 && apt-get install -y --no-install-recommends \
      build-essential cmake git pkg-config patch xz-utils \
      tcl bison flex \
      iverilog \
      nodejs npm \
      python3 python3-pip python3-cairo python3-yaml \
      fonts-dejavu-core \
      libfl2 libreadline8 libtcl8.6 \
 && pip3 install --no-cache-dir --upgrade pip setuptools wheel \
 && pip3 install --no-cache-dir \
      'pywellen ~= 0.20' \
 && npm install -g --no-fund --no-audit netlistsvg \
 && npm cache clean --force \
 && rm -rf /var/lib/apt/lists/* /root/.npm /root/.cache

COPY --from=yosys-builder /usr/local/bin/yosys* /usr/local/bin/
COPY --from=yosys-builder /usr/local/share/yosys/ /usr/local/share/yosys/

COPY vhd2svg.sh /tools/
COPY waveview/ /tools/waveview/
RUN pip3 install --no-cache-dir /tools/waveview/

CMD ["/bin/bash"]
